DOCINT_OFFLINE=true

# --- Service endpoints (local) ---
# BACKEND_HOST=http://localhost:8000
# BACKEND_PUBLIC_HOST=http://localhost:8000
# QDRANT_HOST=http://localhost:6333
# CORS_ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# --- Inference backend (choose one) ---
# Supported providers: ollama | llama.cpp | openai
# Ollama (default)
# MODEL_PROVIDER=ollama
# OPENAI_API_BASE=http://localhost:11434/v1
# EMBED_MODEL=bge-m3
# LLM=gpt-oss:20b
# VLM=qwen3.5:9b

# Llama.cpp 
# model string format: repo;model_file;mmproj_file (mmproj_file optional, defaults to model_file)
# MODEL_PROVIDER=llama.cpp
# OPENAI_API_BASE=http://localhost:8080/v1
# EMBED_MODEL=ggml-org/bge-m3-Q8_0-GGUF;bge-m3-q8_0.gguf
# LLM=unsloth/Qwen3.5-4B-GGUF;Qwen3.5-4B-Q8_0.gguf
# VLM=unsloth/Qwen3.5-9B-GGUF;Qwen3.5-9B-Q4_K_M.gguf;mmproj-F16.gguf

# OpenAI
# MODEL_PROVIDER=openai
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=sk-no-key-required
# EMBED_MODEL=text-embedding-3-small
# LLM=gpt-4o
# VLM=gpt-4o

# --- NER / extraction ---
# NER_ENABLED=true
# NER_MAX_WORKERS=4
# NER_MAX_CHARS=1024
# ENABLE_HATE_SPEECH_DETECTION=true
# HATE_SPEECH_MAX_WORKERS=1

# Graph-assisted retrieval (optional)
# GRAPHRAG_ENABLED=true

# Whisper max workers (optional, for audio transcription)
# WHISPER_MAX_WORKERS=1
