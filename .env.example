DOCINT_OFFLINE=true
# TOKENIZERS_PARALLELISM=false
# PRELOAD_MODELS=true
# USE_DEVICE=cpu
# OPENAI_CTX_WINDOW=8192
# RESPONSE_VALIDATION_ENABLED=true

# --- Service endpoints ---
# Local development defaults:
# BACKEND_HOST=http://localhost:8000
# BACKEND_PUBLIC_HOST=http://localhost:8000
# QDRANT_HOST=http://localhost:6333
# CORS_ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
# SESSIONS_PATH=~/docint/sessions
# SESSION_STORE=sqlite:////absolute/path/to/sessions.db
# Docker-only override if you need to force the in-container SQLite path:
# SESSIONS_DB_PATH=/var/lib/docint/sessions/sessions.sqlite3

# --- Inference backend ---
# Supported providers: openai | vllm
# Set INFERENCE_PROVIDER and OPENAI_API_BASE in this file.
# Docker profiles (cpu / cuda) select hardware only — provider is read from here.

# External routed Ollama
# INFERENCE_PROVIDER=ollama
# INFERENCE_NET=inference-net
# OPENAI_API_BASE=http://ollama:11434/v1
# EMBED_MODEL=bge-m3
# TEXT_MODEL=gemma4:31b-cloud
# VISION_MODEL=gemma4:31b-cloud

# External routed vLLM
# Local development:
# INFERENCE_PROVIDER=vllm
# OPENAI_API_BASE=https://<router-host>/v1
# Docker profiles default to this internal router URL when both compose
# projects join the same shared proxy network:
# INFERENCE_NET=inference-net
# OPENAI_API_BASE=http://vllm-router:9000/v1
# OPENAI_API_KEY=sk-no-key-required
# TEXT_MODEL=Qwen/Qwen3.5-2B
# VISION_MODEL=Qwen/Qwen3.5-2B
# EMBED_MODEL=BAAI/bge-m3
# SPARSE_MODEL=BAAI/bge-m3
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
# WHISPER_MODEL=openai/whisper-large-v3-turbo

# External OpenAI API
# INFERENCE_PROVIDER=openai
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=<your-key-here>
# EMBED_MODEL=text-embedding-3-small
# TEXT_MODEL=gpt-4o
# VISION_MODEL=gpt-4o
# WHISPER_MODEL=whisper-1

# --- NER / extraction ---
# NER_MODEL=gliner-community/gliner_large-v2.5
# NER_ENABLED=true
# NER_MAX_WORKERS=4
# NER_MAX_CHARS=1024
# ENABLE_HATE_SPEECH_DETECTION=true
# HATE_SPEECH_MAX_WORKERS=1

# --- Audio / ASR ---
# WHISPER_MAX_WORKERS=1
# WHISPER_SRC_LANGUAGE=<ISO language code, e.g. "en" for English>
# WHISPER_TASK=transcribe  # or "translate"

# --- Ingestion ---
# INGEST_BENCHMARK_ENABLED=true
# INGESTION_CHUNK_SIZE=50
# DOCSTORE_BATCH_SIZE=100

# --- Graph-assisted retrieval (optional) ---
# GRAPHRAG_ENABLED=true
# GRAPHRAG_NEIGHBOR_HOPS=2
# GRAPHRAG_TOP_K_NODES=50
# GRAPHRAG_MIN_EDGE_WEIGHT=3
# GRAPHRAG_MAX_NEIGHBORS=6

# --- Network proxy (optional) ---
# Put proxy values in this file so Docker Compose interpolation, image builds,
# and running containers use the same settings.
# HTTP_PROXY=http://proxy.example.com:3128
# HTTPS_PROXY=http://proxy.example.com:3128
# NO_PROXY=localhost,127.0.0.1,backend,qdrant,docint-backend,ollama,vllm-router
# Some tools prefer lowercase proxy variables. Duplicate the values below if needed.
# http_proxy=http://proxy.example.com:3128
# https_proxy=http://proxy.example.com:3128
# no_proxy=localhost,127.0.0.1,backend,qdrant,docint-backend,ollama,vllm-router

# --- Docker image overrides (optional) ---
# PYTHON_SLIM_BOOKWORM_IMAGE=registry.example.com/dockerhub/library/python:3.11.12-slim-bookworm
# NVIDIA_CUDA_RUNTIME_IMAGE=registry.example.com/dockerhub/nvidia/cuda:13.0.2-cudnn-runtime-ubuntu22.04
