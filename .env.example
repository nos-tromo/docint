DOCINT_OFFLINE=true

# Docker profile: cpu (default) or cuda. `make` reads this so plain `make up`
# targets the right hardware — no separate up-cuda target needed.
PROFILE=cpu

# TOKENIZERS_PARALLELISM=false
# DOCINT_HOST_PORT=8080
# PRELOAD_MODELS=true
# USE_DEVICE=cpu
# OPENAI_CTX_WINDOW=8192
# RESPONSE_VALIDATION_ENABLED=true

# Language for LLM instructions, hate-speech framing, and clarification
# messages. Default: en. Set to "de" for German deployments — switches the
# entire prompt set under docint/utils/prompts/ from en/ to de/.
# RESPONSE_LANGUAGE=de

# --- Service endpoints ---
# Local development defaults:
# BACKEND_HOST=http://localhost:8000
# BACKEND_PUBLIC_HOST=http://localhost:8000
# QDRANT_HOST=http://localhost:6333
# CORS_ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
# SESSIONS_PATH=~/docint/sessions
# SESSION_STORE=sqlite:////absolute/path/to/sessions.db
# Docker-only override if you need to force the in-container SQLite path:
# SESSIONS_DB_PATH=/var/lib/docint/sessions/sessions.sqlite3

# Proxy bypass: comma-separated extra hostnames appended to NO_PROXY/no_proxy.
# Must start with a leading comma:
# EXTRA_NO_PROXY=,ollama,vllm-router,clip-embed,gliner-ner,rerank-cpu

# --- Inference backend ---
# Supported providers: ollama | openai | vllm
# Set INFERENCE_PROVIDER and OPENAI_API_BASE in this file.
# Docker profiles (cpu / cuda) select hardware only — provider is read from here.

# Ollama
# INFERENCE_PROVIDER=ollama
# INFERENCE_NET=inference-net
# OPENAI_API_BASE=http://ollama:11434/v1
# EMBED_MODEL=bge-m3
# TEXT_MODEL=gemma4:31b-cloud
# VISION_MODEL=gemma4:31b-cloud

# vLLM
# Local development:
# INFERENCE_PROVIDER=vllm
# INFERENCE_NET=inference-net
# OPENAI_API_BASE=http://vllm-router:9000/v1
# OPENAI_API_KEY=sk-no-key-required
# TEXT_MODEL=Qwen/Qwen3.5-2B
# VISION_MODEL=Qwen/Qwen3.5-2B
# EMBED_MODEL=BAAI/bge-m3
# SPARSE_MODEL=BAAI/bge-m3
# RERANK_MODEL=BAAI/bge-reranker-v2-m3

# OpenAI API
# INFERENCE_PROVIDER=openai
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=<your-key-here>
# EMBED_MODEL=text-embedding-3-small
# TEXT_MODEL=gpt-4o
# VISION_MODEL=gpt-4o

# --- NER / extraction ---
# NER runs as a remote service hosted by vllm-service (Ray Serve GLiNER).
# `NER_API_BASE` defaults to the LiteLLM router on the full vllm-service
# stack. For the NER-only deployment shape (no router), point it at the
# GLiNER container's alias on inference-net:
#   NER_API_BASE=http://gliner-ner:8000
# `NER_API_KEY` is sent as `Authorization: Bearer ...` when set. The
# router enforces auth (use `NER_API_KEY=$OPENAI_API_KEY`); the ner-only
# shape has no auth (leave unset).
# NER_MODEL=gliner-community/gliner_large-v2.5
# NER_ENABLED=true
# NER_MAX_WORKERS=4
# NER_MAX_CHARS=1024
# NER_API_BASE=http://vllm-router:4000
# NER_API_KEY=$OPENAI_API_KEY
# NER_THRESHOLD=0.3
# NER_TIMEOUT=30
# ENABLE_HATE_SPEECH_DETECTION=true
# HATE_SPEECH_MAX_WORKERS=1

# --- Reranking ---
# Reranking is always remote (Jina-shape POST /rerank). The defaults
# inherit OPENAI_API_BASE / OPENAI_API_KEY / OPENAI_TIMEOUT, so the
# full vllm-service stack works with no extra config — requests land at
# {OPENAI_API_BASE}/rerank, which the LiteLLM router forwards to vLLM.
# Override only when running the rerank-only deployment shape (CPU
# container hosted by vllm-service) alongside a non-vllm chat/embed
# provider (e.g. Ollama):
#   RERANK_API_BASE=http://rerank-cpu:8000
# The rerank-only container has no built-in auth (leave RERANK_API_KEY
# unset); the full vllm-service router needs the master key — set
# RERANK_API_KEY=$OPENAI_API_KEY explicitly in that case.
# RERANK_API_BASE=http://vllm-router:4000
# RERANK_API_KEY=$OPENAI_API_KEY
# RERANK_TIMEOUT=300

# --- CLIP image+text embedding ---
# CLIP runs as a remote service hosted by vllm-service (FastAPI wrapper
# around transformers CLIPModel). The defaults match the LiteLLM router
# on the full vllm-service stack — clients POST to {CLIP_API_BASE}/clip/
# embed_{image,text} and GET {CLIP_API_BASE}/clip/dimension. For the
# CLIP-only deployment shape (no router), point it at the CLIP
# container's alias on inference-net:
#   CLIP_API_BASE=http://clip-embed:8000
# CLIP_API_KEY is sent as `Authorization: Bearer ...` when set. The
# router enforces auth (use CLIP_API_KEY=$OPENAI_API_KEY); the
# clip-only shape has no auth (leave unset).
# The CLIP model identity is set on the vllm-service container via
# CLIP_MODEL — docint no longer reads IMAGE_EMBED_MODEL. The default
# matches the previous in-process default (openai/clip-vit-base-patch32)
# so existing _images Qdrant collections stay dim-compatible.
# CLIP_API_BASE=http://vllm-router:4000
# CLIP_API_KEY=$OPENAI_API_KEY
# CLIP_TIMEOUT=30

# --- Ingestion ---
# STREAMING_READERS_ENABLED=true
# INGEST_BENCHMARK_ENABLED=true
# INGESTION_CHUNK_SIZE=50
# DOCSTORE_BATCH_SIZE=100

# --- Embedding context budget (separate from OPENAI_CTX_WINDOW) ---
# EMBED_CTX_TOKENS=2048               # ollama: 2048 (default num_ctx) | openai+text-embedding-3-*: 8191 | vllm: $CHAT_MAX_MODEL_LEN
# Raise to 8192 after:
#   ollama create docint-bge-m3 -f deploy/Modelfile.bge-m3
#   and switching EMBED_MODEL to docint-bge-m3 (see docs/deployment.md).
# EMBED_TOKENIZER_REPO=BAAI/bge-m3
# EMBED_CHAR_TOKEN_RATIO=3.5
# EMBED_CTX_SAFETY_MARGIN=0.95
# EMBED_TIMEOUT_SECONDS=1800          # ollama: 1800 | vllm: 600 | openai: 60
# EMBED_BATCH_SIZE=16                 # ollama: 16 | vllm: 64 | openai: 100
# EMBED_MAX_RETRIES=1                 # ollama/vllm: 1 | openai: 2

# --- Graph-assisted retrieval (optional) ---
# GRAPHRAG_ENABLED=true
# GRAPHRAG_NEIGHBOR_HOPS=2
# GRAPHRAG_TOP_K_NODES=50
# GRAPHRAG_MIN_EDGE_WEIGHT=3
# GRAPHRAG_MAX_NEIGHBORS=6
