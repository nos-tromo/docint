DOCINT_OFFLINE=false

# --- Service endpoints (local) ---
BACKEND_HOST=http://localhost:8000
BACKEND_PUBLIC_HOST=http://localhost:8000
QDRANT_HOST=http://localhost:6333
CORS_ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# --- Inference backend (choose one) ---
# Supported providers: llama.cpp | ollama | openai
MODEL_PROVIDER=ollama
OPENAI_API_BASE=http://localhost:11434/v1
OPENAI_API_KEY=sk-no-key-required

# --- Model IDs ---
# Ollama/OpenAI style examples (default local template)
EMBED_MODEL=bge-m3
LLM=gpt-oss:20b
VLM=qwen3-vl:8b

# llama.cpp GGUF style examples (repo;filename)
# EMBED_MODEL=ggml-org/bge-m3-Q8_0-GGUF;bge-m3-q8_0.gguf
# LLM=unsloth/Qwen3-1.7B-GGUF;Qwen3-1.7B-Q4_K_M.gguf
# VLM=Qwen/Qwen3-VL-8B-Instruct-GGUF;Qwen3VL-8B-Instruct-Q4_K_M.gguf

# Shared image embedding model for image ingestion / retrieval
IMAGE_EMBED_MODEL=openai/clip-vit-base-patch32

# --- NER / extraction ---
NER_ENABLED=true
NER_MAX_WORKERS=4
# NER_MAX_CHARS=1024

# Graph-assisted retrieval (optional)
GRAPHRAG_ENABLED=false
# GRAPHRAG_NEIGHBOR_HOPS=1
# GRAPHRAG_TOP_K_NODES=100
# GRAPHRAG_MIN_EDGE_WEIGHT=1
# GRAPHRAG_MAX_NEIGHBORS=6

# --- Image ingestion ---
IMAGE_INGESTION_ENABLED=true
IMAGE_EMBEDDING_ENABLED=true
IMAGE_TAGGING_ENABLED=true
IMAGE_QDRANT_COLLECTION={collection}_images
IMAGE_QDRANT_VECTOR_NAME=image-dense
IMAGE_CACHE_BY_HASH=true
IMAGE_FAIL_ON_EMBED_ERROR=false
IMAGE_FAIL_ON_TAG_ERROR=false
IMAGE_TAGGING_MAX_IMAGE_DIM=1024

# --- Document pipeline ---
PIPELINE_TEXT_COVERAGE_THRESHOLD=0.01
# PIPELINE_ARTIFACTS_DIR=artifacts
PIPELINE_MAX_RETRIES=2
PIPELINE_FORCE_REPROCESS=false
PIPELINE_MAX_WORKERS=4
PIPELINE_ENABLE_VISION_OCR=true
PIPELINE_VISION_OCR_TIMEOUT=60.0
PIPELINE_VISION_OCR_MAX_RETRIES=1
PIPELINE_VISION_OCR_MAX_IMAGE_DIM=1024
PIPELINE_VISION_OCR_MAX_TOKENS=4096

# --- Optional local paths ---
# DATA_PATH=~/docint/data
# QUERIES_PATH=~/docint/queries.txt
# RESULTS_PATH=~/docint/results
# HF_HUB_CACHE=~/.cache/huggingface/hub
# LLAMA_CPP_CACHE=~/.cache/llama.cpp
# LOG_PATH=.logs/docint.log

# --- Optional runtime ---
# SESSION_STORE=sqlite:///sessions.db
# PRELOAD_MODELS=false
