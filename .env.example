DOCINT_OFFLINE=true
# TOKENIZERS_PARALLELISM=false
# DOCINT_HOST_PORT=8080
# PRELOAD_MODELS=true
# OPENAI_CTX_WINDOW=8192
# RESPONSE_VALIDATION_ENABLED=true

# Language for LLM instructions, hate-speech framing, and clarification
# messages. Default: en. Set to "de" for German deployments — switches the
# entire prompt set under docint/utils/prompts/ from en/ to de/.
# RESPONSE_LANGUAGE=en

# --- Service endpoints ---
# Local development defaults:
# BACKEND_HOST=http://localhost:8000
# BACKEND_PUBLIC_HOST=http://localhost:8000
# QDRANT_HOST=http://localhost:6333
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# SESSIONS_PATH=~/docint/sessions
# SESSION_STORE=sqlite:////absolute/path/to/sessions.db
# Docker-only override if you need to force the in-container SQLite path:
# SESSIONS_DB_PATH=/var/lib/docint/sessions/sessions.sqlite3

# --- User authentication ---
# The React SPA does not inject an authenticated user header on its own.
# For single-user Docker or local setups, set DOCINT_DEFAULT_IDENTITY so
# session-backed chat and /sessions/list use the same owner. If you deploy
# behind a trusted proxy that injects a user header instead, point
# DOCINT_AUTH_HEADER at that header name.
# DOCINT_DEFAULT_IDENTITY=operator
# DOCINT_AUTH_HEADER=X-Auth-User

# Proxy bypass: comma-separated extra hostnames appended to NO_PROXY/no_proxy.
# Must start with a leading comma:
# EXTRA_NO_PROXY=,ollama,vllm-router,clip-only,gliner-only,rerank-only,nextext-backend

# --- Inference backend ---
# Supported providers: ollama | openai | vllm
# For local development, set INFERENCE_PROVIDER yourself.
# Set INFERENCE_PROVIDER and OPENAI_API_BASE in this file.

# Ollama
# INFERENCE_PROVIDER=ollama
# INFERENCE_NET=inference-net
# OPENAI_API_BASE=http://ollama:11434/v1
# EMBED_MODEL=${EMBED_MODEL:-bge-m3}
# TEXT_MODEL=${TEXT_MODEL:-gemma4:31b-cloud}
# VISION_MODEL=${VISION_MODEL:-gemma4:31b-cloud}

# vLLM
# INFERENCE_PROVIDER=vllm
# INFERENCE_NET=inference-net
# OPENAI_API_BASE=http://vllm-router:4000/v1
# OPENAI_API_KEY=sk-no-key-required
# TEXT_MODEL=${TEXT_MODEL:-google/gemma-4-E2B-it}
# VISION_MODEL=${VISION_MODEL:-google/gemma-4-E2B-it}
# EMBED_MODEL=${EMBED_MODEL:-BAAI/bge-m3}
# SPARSE_MODEL=${SPARSE_MODEL:-BAAI/bge-m3}
# RERANK_MODEL=${RERANK_MODEL:-BAAI/bge-reranker-v2-m3}

# OpenAI API
# INFERENCE_PROVIDER=openai
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=<your-key-here>
# EMBED_MODEL=${EMBED_MODEL:-text-embedding-3-small}
# TEXT_MODEL=${TEXT_MODEL:-gpt-4o}
# VISION_MODEL=${VISION_MODEL:-gpt-4o}

# --- NER / extraction ---
# NER runs as a remote service hosted by vllm-service (Ray Serve GLiNER).
# `NER_API_BASE` defaults to the LiteLLM router on the full vllm-service
# stack. For the gliner-only deployment shape (no router), point it at the
# GLiNER container's alias on inference-net:
#   NER_API_BASE=http://gliner-only:8000
# `NER_API_KEY` is sent as `Authorization: Bearer ...` when set. The
# router enforces auth (use `NER_API_KEY=$OPENAI_API_KEY`); the gliner-only
# shape has no auth (leave unset).
# NER_MODEL=${NER_MODEL:-gliner-community/gliner_large-v2.5}
# NER_ENABLED=true
# NER_MAX_WORKERS=4
# NER_MAX_CHARS=1024
# NER_API_BASE=http://vllm-router:4000
# NER_API_KEY=$OPENAI_API_KEY
# NER_THRESHOLD=0.3
# NER_TIMEOUT=30
# ENABLE_HATE_SPEECH_DETECTION=true
# HATE_SPEECH_MAX_WORKERS=1

# --- Analysis graph view ---
# Default and ceiling for the entity-graph node count (Analysis -> NER -> Graph).
# The SPA seeds its node-count control from NER_GRAPH_TOP_K and lets the user
# raise it live up to NER_GRAPH_MAX_TOP_K. Raise the max for large corpora.
# NER_GRAPH_TOP_K=80
# NER_GRAPH_MAX_TOP_K=500

# --- Reranking ---
# Reranking is always remote (Jina-shape POST /rerank). The defaults
# inherit OPENAI_API_BASE / OPENAI_API_KEY / OPENAI_TIMEOUT, so the
# full vllm-service stack works with no extra config — requests land at
# {OPENAI_API_BASE}/rerank, which the LiteLLM router forwards to vLLM.
# Override only when running the rerank-only deployment shape (CPU
# container hosted by vllm-service) alongside a non-vllm chat/embed
# provider (e.g. Ollama):
#   RERANK_API_BASE=http://rerank-only:8000
# The rerank-only container has no built-in auth (leave RERANK_API_KEY
# unset); the full vllm-service router needs the master key — set
# RERANK_API_KEY=$OPENAI_API_KEY explicitly in that case.
# RERANK_API_BASE=http://vllm-router:4000
# RERANK_API_KEY=$OPENAI_API_KEY
# RERANK_TIMEOUT=300

# --- CLIP image+text embedding ---
# CLIP runs as a remote service hosted by vllm-service (FastAPI wrapper
# around transformers CLIPModel). The defaults match the LiteLLM router
# on the full vllm-service stack — clients POST to {CLIP_API_BASE}/clip/
# embed_{image,text} and GET {CLIP_API_BASE}/clip/dimension. For the
# CLIP-only deployment shape (no router), point it at the CLIP
# container's alias on inference-net:
#   CLIP_API_BASE=http://clip-only:8000
# CLIP_API_KEY is sent as `Authorization: Bearer ...` when set. The
# router enforces auth (use CLIP_API_KEY=$OPENAI_API_KEY); the
# clip-only shape has no auth (leave unset).
# The CLIP model identity is set on the vllm-service container via
# CLIP_MODEL — docint no longer reads IMAGE_EMBED_MODEL. The default
# matches the previous in-process default (openai/clip-vit-base-patch32)
# so existing _images Qdrant collections stay dim-compatible.
# CLIP_API_BASE=http://vllm-router:4000
# CLIP_API_KEY=$OPENAI_API_KEY
# CLIP_TIMEOUT=30

# --- Nextext media processing (social multimodal video/audio) ---
# Social-export batches can link video/audio to postings. docint ships no local
# media runtime — it forwards each clip to a remote Nextext service
# (https://github.com/nos-tromo/nextext), which transcribes it and returns a
# docint.jsonl transcript plus a keyframes.zip; docint ingests the transcript as
# text and the keyframes as CLIP image points. Leave NEXTEXT_API_BASE unset to
# disable this path — video/audio rows are then skipped fail-soft (images still
# ingest via CLIP, unaffected).
#
# NEXTEXT_API_BASE MUST include Nextext's /api/v1 prefix: docint calls {base}/jobs
# and Nextext mounts the jobs router under /api/v1, so omitting it 404s every
# request.
#   NEXTEXT_API_BASE=http://nextext-backend:8000/api/v1
# NEXTEXT_API_KEY is sent as `Authorization: Bearer ...` when set; current Nextext
# does not validate it (forward-compatible no-op). Nextext instead requires a
# request identity, and docint sends none — so on the Nextext side the operator
# must set NEXTEXT_DEFAULT_IDENTITY to a non-empty value (e.g. docint) or every
# job is rejected 401 (see Nextext's own .env.example).
# NEXTEXT_API_BASE=
# NEXTEXT_API_KEY=
# NEXTEXT_TIMEOUT=30                   # per-request HTTP timeout (seconds)
# NEXTEXT_POLL_INTERVAL=2              # delay between job-status polls (seconds)
# NEXTEXT_POLL_MAX_SECONDS=1800        # wall-clock budget per job before status "timeout"
#
# Keyframe sampling is configured HERE (docint side) and forwarded to Nextext as
# per-job options — Nextext has no server-side keyframe knob; its schema defaults
# only apply to callers that omit these fields.
# KEYFRAMES_PER_MINUTE=4               # target keyframes sampled per minute of video
# KEYFRAMES_MAX=20                     # hard ceiling on frames per clip (Nextext rejects > 200)
# KEYFRAME_DEDUP_COSINE=0.95           # [0..1] client-side: prune near-duplicate keyframes before storage

# --- Ingestion ---
# STREAMING_READERS_ENABLED=true
# INGEST_BENCHMARK_ENABLED=true
# INGESTION_BATCH_SIZE=50
# DOCSTORE_BATCH_SIZE=100
# INGEST_MANIFEST_ENABLED=true         # SQLite ingest manifest; also caches Nextext transcripts by media-file hash so re-ingesting an unchanged clip skips the Nextext round-trip

# --- Embedding context budget (separate from OPENAI_CTX_WINDOW) ---
# EMBED_CTX_TOKENS=2048               # ollama: 2048 (default num_ctx) | openai+text-embedding-3-*: 8191 | vllm: $CHAT_MAX_MODEL_LEN
# Raise to 8192 after:
#   ollama create docint-bge-m3 -f deploy/Modelfile.bge-m3
#   and switching EMBED_MODEL to docint-bge-m3 (see docs/deployment.md).
# EMBED_TOKENIZER_REPO=BAAI/bge-m3
# EMBED_CHAR_TOKEN_RATIO=3.5
# EMBED_CTX_SAFETY_MARGIN=0.95
# EMBED_TIMEOUT_SECONDS=1800          # ollama: 1800 | vllm: 600 | openai: 60
# EMBED_BATCH_SIZE=16                 # ollama: 16 | vllm: 64 | openai: 100
# EMBED_MAX_RETRIES=1                 # ollama/vllm: 1 | openai: 2

# --- Graph-assisted retrieval (optional) ---
# GRAPHRAG_ENABLED=true
# GRAPHRAG_NEIGHBOR_HOPS=2
# GRAPHRAG_TOP_K_NODES=50
# GRAPHRAG_MIN_EDGE_WEIGHT=3
# GRAPHRAG_MAX_NEIGHBORS=6
