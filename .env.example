DOCINT_OFFLINE=true
NER_ENABLED=true
NER_MAX_WORKERS=4
# PRELOAD_MODELS=false

# --- Llama.cpp (default) ---
# No extra settings needed; the profile sets OPENAI_API_BASE and
# MODEL_PROVIDER automatically.
# Llama.cpp models must be in GGUF format. You can convert them yourself or download from Hugging Face
# using the {repo_id;filename} syntax below. Example:
# EMBED_MODEL=ggml-org/bge-m3-Q8_0-GGUF;bge-m3-q8_0.gguf
# LLM=Qwen/Qwen3-VL-8B-Instruct-GGUF;Qwen3VL-8B-Instruct-Q8_0.gguf
# VLM=unsloth/Qwen3-VL-8B-Instruct-GGUF;Qwen3-VL-8B-Instruct-Q8_0.gguf

# --- Ollama ---
MODEL_PROVIDER=ollama
OPENAI_API_BASE=http://localhost:11434/v1
EMBED_MODEL=bge-m3
LLM=gpt-oss:20b
VLM=qwen3-vl:8b

# --- External OpenAI API ---
# MODEL_PROVIDER=openai
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=sk-your-key-here
# EMBED_MODEL=text-embedding-3-small
# LLM=gpt-4o
# VLM=gpt-4o
