DOCINT_OFFLINE=true
# SESSIONS_DB_PATH=/var/lib/docint/sessions/sessions.sqlite3
# SESSION_STORE=sqlite:////var/lib/docint/sessions/sessions.sqlite3
# TOKENIZERS_PARALLELISM=false
# PRELOAD_MODELS=true
# USE_DEVICE=cpu
# OPENAI_CTX_WINDOW=8192
# RESPONSE_VALIDATION_ENABLED=true

# --- Ollama (default) ---
# Use a cpu-ollama / cuda-ollama profile. OPENAI_API_BASE and
# INFERENCE_PROVIDER are set automatically by the profile.
# EMBED_MODEL=bge-m3
# TEXT_MODEL=gpt-oss:20b
# VISION_MODEL=qwen3.5:9b

# --- vLLM (CUDA only) ---
# Use the cuda-vllm profile. The profile sets INFERENCE_PROVIDER=vllm and routes the
# backend through an internal nginx service at http://vllm-router:9000/v1.
# The backend container has NO GPU reservation — all GPU workloads are handled by
# dedicated vLLM service containers. Auxiliary local models (GLiNER, CLIP) run on
# CPU only, so they never compete with the vLLM workers for VRAM.
# The bundled profile serves TEXT_MODEL, EMBED_MODEL, SPARSE_MODEL, RERANK_MODEL,
# and WHISPER_MODEL directly.
# Set VISION_MODEL equal to TEXT_MODEL unless you add a separate routed vision service.
# On single-GPU hosts, the compose defaults already pin every vLLM service to GPU 0.
# Override the per-service GPU mapping below only if you want to split work across
# multiple devices.
# HF_TOKEN=hf_your_token_here
# OPENAI_API_KEY=sk-no-key-required
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# configure multi-gpu-setup
# TENSOR_PARALLEL_SIZE=2

# chat
# TEXT_MODEL=Qwen/Qwen3.5-2B
# VISION_MODEL=Qwen/Qwen3.5-2B
# CHAT_CUDA_VISIBLE_DEVICES=0,1
# CHAT_GPU_MEMORY_UTILIZATION=0.55

# embed
# EMBED_MODEL=BAAI/bge-m3
# SPARSE_MODEL=BAAI/bge-m3
# EMBED_CUDA_VISIBLE_DEVICES=1
# EMBED_GPU_MEMORY_UTILIZATION=0.1
# EMBED_HF_OVERRIDES={"architectures":["BgeM3EmbeddingModel"]}

# rerank
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_CUDA_VISIBLE_DEVICES=1
# RERANK_GPU_MEMORY_UTILIZATION=0.1

# audio / asr
# WHISPER_MODEL=openai/whisper-large-v3-turbo
# AUDIO_CUDA_VISIBLE_DEVICES=0,1
# AUDIO_GPU_MEMORY_UTILIZATION=0.15
# VLLM_MAX_AUDIO_CLIP_FILESIZE_MB=200  # vLLM max upload size for audio files (default: 200 MB)

# CHAT_MAX_MODEL_LEN=4096  # defaults to OPENAI_CTX_WINDOW if set
# CHAT_MAX_NUM_SEQS=8
# CHAT_MAX_NUM_BATCHED_TOKENS=16384
# CHAT_ENABLE_PREFIX_CACHING=true
# CHAT_TEMPLATE_CONTENT_FORMAT=openai
# CHAT_DEFAULT_CHAT_TEMPLATE_KWARGS={"enable_thinking":false}
# CHAT_LIMIT_MM_PER_PROMPT={"image":4}
# EMBED_RUNNER=pooling
# EMBED_CONVERT=embed
# RERANK_RUNNER=pooling

# --- External OpenAI API ---
# Use a cpu-openai / cuda-openai profile and set the variables below.
# OPENAI_API_KEY=sk-your-key-here
# EMBED_MODEL=text-embedding-3-small
# TEXT_MODEL=gpt-4o
# VISION_MODEL=gpt-4o

# --- NER / extraction ---
# NER_MODEL=urchade/gliner_multi-v2.1
# NER_ENABLED=true
# NER_MAX_WORKERS=4
# NER_MAX_CHARS=1024
# ENABLE_HATE_SPEECH_DETECTION=true
# HATE_SPEECH_MAX_WORKERS=1

# --- Ingestion ---
# INGEST_BENCHMARK_ENABLED=true
# INGESTION_CHUNK_SIZE=50
# DOCSTORE_BATCH_SIZE=100

# Graph-assisted retrieval (optional)
# GRAPHRAG_ENABLED=true
# GRAPHRAG_NEIGHBOR_HOPS=2
# GRAPHRAG_TOP_K_NODES=50
# GRAPHRAG_MIN_EDGE_WEIGHT=3
# GRAPHRAG_MAX_NEIGHBORS=6

# Whisper max workers (optional, for audio transcription)
# WHISPER_MAX_WORKERS=1

# --- Network proxy (optional) ---
# If your host must use an outbound proxy, put the values below in this file and
# start compose with `docker compose --env-file .env.docker ...` so the same
# proxy settings reach both image builds and running containers.
# HTTP_PROXY=http://proxy.example.com:3128
# HTTPS_PROXY=http://proxy.example.com:3128
# NO_PROXY=localhost,127.0.0.1,qdrant,ollama-server,vllm-router,vllm-chat,vllm-embed,vllm-audio,vllm-rerank,backend-net
# Some tools prefer lowercase proxy variables. Duplicate the values below if needed.
# http_proxy=http://proxy.example.com:3128
# https_proxy=http://proxy.example.com:3128
# no_proxy=localhost,127.0.0.1,qdrant,ollama-server,vllm-router,vllm-chat,vllm-embed,vllm-audio,vllm-rerank,backend-net
# If Docker Hub is blocked directly in your environment, point these at an
# internal mirror or approved registry namespace that proxies the same images.
