DOCINT_OFFLINE=true
# TOKENIZERS_PARALLELISM=false
# PRELOAD_MODELS=true
# RESPONSE_VALIDATION_ENABLED=false

# --- Network proxy (optional) ---
# If your host must use an outbound proxy, put the values below in this file and
# start compose with `docker compose --env-file .env.docker ...` so the same
# proxy settings reach both image builds and running containers.
# HTTP_PROXY=http://proxy.example.com:3128
# HTTPS_PROXY=http://proxy.example.com:3128
# NO_PROXY=localhost,127.0.0.1,qdrant,ollama-server,vllm-router,vllm-chat,vllm-embed,vllm-rerank,backend-net
# Some tools prefer lowercase proxy variables. Duplicate the values below if needed.
# http_proxy=http://proxy.example.com:3128
# https_proxy=http://proxy.example.com:3128
# no_proxy=localhost,127.0.0.1,qdrant,ollama-server,vllm-router,vllm-chat,vllm-embed,vllm-rerank,backend-net

# --- Inference backend ---
# Default profile comes from .env: COMPOSE_PROFILES=cpu-ollama
# Start default stack:
#   docker compose up
# Override with an explicit profile:
#   docker compose --profile cpu-openai up
#   docker compose --profile cuda-ollama up
#   docker compose --profile cuda-openai up
#   docker compose --profile cuda-vllm up

# --- Ollama (default) ---
# Use a cpu-ollama / cuda-ollama profile. OPENAI_API_BASE and
# INFERENCE_PROVIDER are set automatically by the profile.
# EMBED_MODEL=bge-m3
# TEXT_MODEL=gpt-oss:20b
# VISION_MODEL=qwen3.5:9b

# --- vLLM (CUDA only) ---
# Use the cuda-vllm profile. The profile sets INFERENCE_PROVIDER=vllm and routes the
# backend through an internal nginx service at http://vllm-router:9000/v1.
# The bundled profile serves TEXT_MODEL, EMBED_MODEL, and RERANK_MODEL directly.
# Set VISION_MODEL equal to TEXT_MODEL unless you add a separate routed vision service.
# On single-GPU hosts, the compose defaults already pin every vLLM service to GPU 0.
# Override the per-service GPU mapping below only if you want to split work across
# multiple devices.
# HF_TOKEN=hf_your_token_here
# OPENAI_API_KEY=sk-no-key-required
# TEXT_MODEL=Qwen/Qwen3.5-2B
# VISION_MODEL=Qwen/Qwen3.5-2B
# EMBED_MODEL=BAAI/bge-m3
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
# VLLM_CHAT_GPU_MEMORY_UTILIZATION=0.9
# VLLM_CHAT_MAX_MODEL_LEN=4096
# VLLM_CHAT_ENABLE_PREFIX_CACHING=true
# VLLM_CHAT_TEMPLATE_CONTENT_FORMAT=openai
# VLLM_CHAT_DEFAULT_CHAT_TEMPLATE_KWARGS={"enable_thinking":false}
# VLLM_CHAT_LIMIT_MM_PER_PROMPT={"image":4}
# VLLM_EMBED_RUNNER=pooling
# VLLM_EMBED_CONVERT=embed
# VLLM_EMBED_GPU_MEMORY_UTILIZATION=0.5
# VLLM_RERANK_RUNNER=pooling
# VLLM_RERANK_GPU_MEMORY_UTILIZATION=0.3
# VLLM_CHAT_CUDA_VISIBLE_DEVICES=0
# VLLM_EMBED_CUDA_VISIBLE_DEVICES=0
# VLLM_RERANK_CUDA_VISIBLE_DEVICES=0
# Leave OPENAI_DIMENSIONS unset for BGE-on-vLLM unless the served model supports
# reduced-dimension embeddings.

# --- External OpenAI API ---
# Use a cpu-openai / cuda-openai profile and set the variables below.
# OPENAI_API_KEY=sk-your-key-here
# EMBED_MODEL=text-embedding-3-small
# TEXT_MODEL=gpt-4o
# VISION_MODEL=gpt-4o

# --- NER / extraction ---
# NER_ENABLED=true
# NER_MAX_WORKERS=4
# NER_MAX_CHARS=1024
# ENABLE_HATE_SPEECH_DETECTION=true
# HATE_SPEECH_MAX_WORKERS=1

# --- Ingestion ---
# INGEST_BENCHMARK_ENABLED=true
# INGESTION_CHUNK_SIZE=50
# DOCSTORE_BATCH_SIZE=100

# Graph-assisted retrieval (optional)
# GRAPHRAG_ENABLED=true
# GRAPHRAG_NEIGHBOR_HOPS=2
# GRAPHRAG_TOP_K_NODES=50
# GRAPHRAG_MIN_EDGE_WEIGHT=3
# GRAPHRAG_MAX_NEIGHBORS=6

# Whisper max workers (optional, for audio transcription)
# WHISPER_MAX_WORKERS=1
