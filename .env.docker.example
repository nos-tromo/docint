DOCINT_OFFLINE=true
# SESSIONS_DB_PATH=/var/lib/docint/sessions/sessions.sqlite3
# SESSION_STORE=sqlite:////var/lib/docint/sessions/sessions.sqlite3
# TOKENIZERS_PARALLELISM=false
# PRELOAD_MODELS=true
# USE_DEVICE=cpu
# OPENAI_CTX_WINDOW=8192
# RESPONSE_VALIDATION_ENABLED=true

# --- Ollama (default) ---
# Use a cpu-ollama / cuda-ollama profile. OPENAI_API_BASE and
# INFERENCE_PROVIDER are set automatically by the profile.
# EMBED_MODEL=bge-m3
# TEXT_MODEL=gpt-oss:20b
# VISION_MODEL=qwen3.5:9b

# --- External routed vLLM ---
# Use the cpu-vllm or cuda-vllm profile. Docint expects one routed base URL
# from a standalone vLLM deployment and does not start router/chat/embed/
# rerank/audio containers itself.
# When both compose projects join the same external proxy network, the default
# internal router URL is:
# PROXY_NETWORK=proxy-net
# OPENAI_API_BASE=http://vllm-router:9000/v1
# OPENAI_API_KEY=sk-no-key-required
# TEXT_MODEL=Qwen/Qwen3.5-2B
# VISION_MODEL=Qwen/Qwen3.5-2B
# EMBED_MODEL=BAAI/bge-m3
# SPARSE_MODEL=BAAI/bge-m3
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
# WHISPER_MODEL=openai/whisper-large-v3-turbo
# WHISPER_SRC_LANGUAGE=<ISO language code, e.g. "en" for English>
# WHISPER_MAX_WORKERS=1
# The standalone vLLM app owns deploy-time settings such as CHAT_*,
# EMBED_*, RERANK_*, AUDIO_*, TENSOR_PARALLEL_SIZE, HF_HUB_OFFLINE,
# TRANSFORMERS_OFFLINE, and VLLM_MAX_AUDIO_CLIP_FILESIZE_MB.

# --- External OpenAI API ---
# Use a cpu-openai / cuda-openai profile and set the variables below.
# OPENAI_API_KEY=sk-your-key-here
# EMBED_MODEL=text-embedding-3-small
# TEXT_MODEL=gpt-4o
# VISION_MODEL=gpt-4o

# --- NER / extraction ---
# NER_MODEL=urchade/gliner_multi-v2.1
# NER_ENABLED=true
# NER_MAX_WORKERS=4
# NER_MAX_CHARS=1024
# ENABLE_HATE_SPEECH_DETECTION=true
# HATE_SPEECH_MAX_WORKERS=1

# --- Ingestion ---
# INGEST_BENCHMARK_ENABLED=true
# INGESTION_CHUNK_SIZE=50
# DOCSTORE_BATCH_SIZE=100

# --- Graph-assisted retrieval (optional) ---
# GRAPHRAG_ENABLED=true
# GRAPHRAG_NEIGHBOR_HOPS=2
# GRAPHRAG_TOP_K_NODES=50
# GRAPHRAG_MIN_EDGE_WEIGHT=3
# GRAPHRAG_MAX_NEIGHBORS=6

# --- Network proxy (optional) ---
# If your host must use an outbound proxy, put the values below in this file and
# start compose with `docker compose --env-file .env.docker ...` so the same
# proxy settings reach both image builds and running containers.
# HTTP_PROXY=http://proxy.example.com:3128
# HTTPS_PROXY=http://proxy.example.com:3128
# NO_PROXY=localhost,127.0.0.1,qdrant,ollama-server,backend-net,docint-backend,docint-frontend,vllm-router,vllm.example.com
# Some tools prefer lowercase proxy variables. Duplicate the values below if needed.
# http_proxy=http://proxy.example.com:3128
# https_proxy=http://proxy.example.com:3128
# no_proxy=localhost,127.0.0.1,qdrant,ollama-server,backend-net,docint-backend,docint-frontend,vllm-router,vllm.example.com

# --- Docker image overrides (optional) ---
# PYTHON_SLIM_BOOKWORM_IMAGE=registry.example.com/dockerhub/library/python:3.11-slim-bookworm
# PYTHON_SLIM_IMAGE=registry.example.com/dockerhub/library/python:3.11-slim
# NVIDIA_CUDA_RUNTIME_IMAGE=registry.example.com/dockerhub/nvidia/cuda:13.0.2-cudnn-runtime-ubuntu22.04
